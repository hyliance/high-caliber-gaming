# ─────────────────────────────────────────────────────────────────────
# High Caliber Gaming — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
# Get a free Postgres DB at https://neon.tech
# Format: postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/high_caliber_gaming"

# ── NextAuth ─────────────────────────────────────────────────────────
# Production: set to your Vercel URL, e.g. https://hcg.vercel.app
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-character-secret"

# ── OAuth Providers (all optional for demo mode) ─────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Discord: https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Twitch: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ── Stripe (optional — needed for real wagering/payments) ────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Public platform config ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_NAME="High Caliber Gaming"

# ── Optional services (not required for basic deploy) ────────────────
# Redis (for real-time leaderboards, caching)
REDIS_URL="redis://localhost:6379"

# Email (SendGrid)
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@highcalibergaming.gg"

# AWS S3 (for media uploads)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="hcg-media"
CLOUDFRONT_URL="https://cdn.highcalibergaming.gg"
